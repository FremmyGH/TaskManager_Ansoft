<Window x:Class="TaskManager.View.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:conv="clr-namespace:TaskManager.Model.Converters"
        xmlns:lib="clr-namespace:TaskManager.Model.Lib.ControlsWPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:m="clr-namespace:TaskManager.Model"
        xmlns:local="clr-namespace:TaskManager.View" 
        xmlns:vm="clr-namespace:TaskManager.ViewModel" 
        d:DataContext="{d:DesignInstance Type=vm:TaskEditContext}"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Изменение задачи" Height="450" Width="800">
    <Window.Resources>
        <ObjectDataProvider x:Key="PriorityEnumValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:TodoPriority"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <conv:EnumDescriptionConverter x:Key="EnumConv"/>
    </Window.Resources>

    <!-- Закрытие окна -->
    <i:Interaction.Triggers>
        <i:DataTrigger Binding="{Binding DialogResult}" Value="True">
            <i:ChangePropertyAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                                    PropertyName="DialogResult" Value="True"/>
        </i:DataTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="20" lib:GridHelper.Rows="Auto Auto Auto * Auto">
        <!-- Название -->
        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="Название*" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
        </StackPanel>

        <!-- Описание -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Описание" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Description}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <!-- Приоритет и Срок -->
        <Grid Grid.Row="2" lib:GridHelper.Columns="* *">
            <StackPanel Margin="0,0,10,10">
                <TextBlock Text="Приоритет" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource PriorityEnumValues}}" 
                          SelectedItem="{Binding Priority}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumConv}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,0,10">
                <TextBlock Text="Срок исполнения" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding DueDate, ValidatesOnNotifyDataErrors=True}"/>
            </StackPanel>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Width="90" Height="30" IsDefault="True" Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="IsEnabled" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasErrors}" Value="False">
                                <Setter Property="IsEnabled" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- Команда закрытия системная (IsCancel автоматически закроет окно) -->
            <Button Content="Отмена" Width="90" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
